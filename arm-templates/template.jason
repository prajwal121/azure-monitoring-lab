                "[resourceId('Microsoft.Network/virtualNetworks/subnets', parameters('virtualNetworks_vm_linux_lab_vnet_name'), 'default')]",
                "[resourceId('Microsoft.Network/networkSecurityGroups', parameters('networkSecurityGroups_vm_linux_lab_nsg_name'))]"
            ],
            "kind": "Regular",
