        {
            "type": "Microsoft.Network/networkInterfaces",
            "apiVersion": "2025-05-01",
            "name": "[parameters('networkInterfaces_vm_linux_lab417_z1_name')]",
            "location": "centralindia",
            "dependsOn": [
